#include <windows.h>

IDI_ICON1 ICON "icons/app_icon.ico"

VS_VERSION_INFO     VERSIONINFO
FILEVERSION         @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION      @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK       0x3fL
FILEFLAGS           0x0L
FILEOS              VOS_NT_WINDOWS32
FILETYPE            VFT_APP
FILESUBTYPE         0x0L
BEGIN
BLOCK "StringFileInfo"
BEGIN
    BLOCK "040904E4"
    BEGIN
        VALUE "CompanyName", "Konstantin Tan"
        VALUE "FileDescription", "IRON NEST Combat Reporter"
        VALUE "FileVersion", "@PROJECT_VERSION@"
        VALUE "InternalName", "iron_reporter"
        VALUE "LegalCopyright", "Copyright (c) 2026 Konstantin Tan. Licensed under GNU GPL v3"
        VALUE "ProductName", "Iron Reporter"
        VALUE "ProductVersion", "@PROJECT_VERSION@"
    END

    BLOCK "041904E1"
    BEGIN
    VALUE "CompanyName", "Konstantin Tan"
    VALUE "FileDescription", "IRON NEST Боевой Докладчик"
    VALUE "FileVersion", "@PROJECT_VERSION@"
    VALUE "InternalName", "iron_reporter"
    VALUE "LegalCopyright", "Copyright (c) 2026 Konstantin Tan. Licensed under GNU GPL v3"
    VALUE "ProductName", "Iron Reporter"
    VALUE "ProductVersion", "@PROJECT_VERSION@"
    END
END

BLOCK "VarFileInfo"
BEGIN
    VALUE "Translation", 0x409, 1252, 0x419, 1251
END
END
